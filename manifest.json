{
  "required_api_version": "^2.0.0",  
  "name": "Shortcuts & Groups Manager",
  "description": "Quickly launch directories, files, URLs, shell commands, or multi-item groups.",
  "developer_name": "DroidLinux",
  "icon": "images/icon.png",
  "options": {
    "query_debounce": 0.1
  },
  "preferences": [
    {
      "id": "kw",
      "type": "keyword",
      "name": "Shortcuts Activation Keyword",
      "default_value": "q"
    },
    {
      "id": "shortcuts_path",
      "type": "text",
      "name": "Shortcuts JSON Path (Optional)",
      "default_value": "~/.config/ulauncher/shortcuts.json"
    }
  ]
}
